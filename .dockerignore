# Used when building from monorepo root, e.g.:
#   docker build -f apps/api/Dockerfile -t toonexpo-api .
# Docker only reads this file (context root), not nested .dockerignore files.

# Dependencies and build output
node_modules
**/node_modules
.next
**/.next
dist
**/dist
build
**/build
coverage
**/coverage
.turbo
**/.turbo
*.tsbuildinfo
**/*.tsbuildinfo

# Environment and secrets (never in image context)
.env
.env.*
!.env.example

# Version control and IDE
.git
**/.git
.gitignore
.idea
.vscode
.cursor
.DS_Store
Thumbs.db

# CI, hooks, local tooling (not needed to build the API image)
.github
.husky
.load
load
scripts

# Docs and markdown (keep root README for image metadata if needed)
docs
*.md
!README.md
AGENTS.md
LICENSE

# Tests (not needed in production image)
**/test
**/*.spec.ts
**/*.test.ts
**/*.e2e-spec.ts

# Prisma generated client (rebuilt during image build)
packages/db/src/generated

# OS, logs, caches
*.log
tmp
temp
.cache
**/playwright-report
**/test-results
