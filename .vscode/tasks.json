{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "API",
      "type": "shell",
      "command": "pnpm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/api",
        "env": {
          "FORCE_COLOR": "1"
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "icon": {
        "id": "server",
        "color": "terminal.ansiGreen"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false,
        "group": "toonexpo-dev"
      }
    },
    {
      "label": "Web",
      "type": "shell",
      "command": "pnpm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/web",
        "env": {
          "FORCE_COLOR": "1"
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "icon": {
        "id": "browser",
        "color": "terminal.ansiBlue"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false,
        "group": "toonexpo-dev"
      }
    },
    {
      "label": "Dev: API + Web",
      "dependsOn": ["API", "Web"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
