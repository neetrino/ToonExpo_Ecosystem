{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "AUTH_SECRET",
    "AUTH_URL",
    "DATABASE_URL",
    "DIRECT_URL",
    "APP_URL",
    "API_URL",
    "NEXT_PUBLIC_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "AUTH_SECRET",
        "AUTH_URL",
        "DATABASE_URL",
        "APP_URL",
        "API_URL",
        "NEXT_PUBLIC_API_URL"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["AUTH_SECRET", "AUTH_URL", "DATABASE_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
