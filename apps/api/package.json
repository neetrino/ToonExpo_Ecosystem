{
  "name": "@toonexpo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ToonExpo NestJS product API",
  "scripts": {
    "predev": "pnpm --filter @toonexpo/db db:generate",
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/throttler": "6.5.0",
    "@sentry/nestjs": "^10.66.0",
    "@toonexpo/contracts": "workspace:*",
    "@toonexpo/db": "workspace:*",
    "@toonexpo/shared": "workspace:*",
    "@upstash/redis": "^1.38.0",
    "argon2": "0.44.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "helmet": "8.3.0",
    "image-size": "^2.0.2",
    "nestjs-pino": "4.6.1",
    "passport": "0.7.0",
    "passport-custom": "1.1.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "resend": "^6.17.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.28",
    "@toonexpo/config": "workspace:*",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.10.1",
    "@types/passport": "1.0.17",
    "@types/supertest": "6.0.3",
    "eslint": "^9.39.2",
    "pino-pretty": "13.1.3",
    "supertest": "7.1.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  }
}
