# Shared local development URLs
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Vercel (apps/web) — configure only frontend-safe values in Vercel.
# Browser calls Nest directly (no Next.js proxy/rewrite).
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SENTRY_DSN=

# Google Cloud Run (apps/api) — store secrets in Secret Manager, never Vercel.
# Database (required by NestJS / Prisma)
DATABASE_URL=""
# Optional: Neon non-pooled URL for migrations when DATABASE_URL uses a pooler
DIRECT_URL=""

# NestJS authentication
AUTH_SECRET=""
# Leave COOKIE_DOMAIN unset (host-only cookies on the API origin).
# COOKIE_DOMAIN=
# Optional override. When unset: lax for same hostname (local), none for cross-host (Vercel → Cloud Run).
# COOKIE_SAME_SITE=none

# Database seed (optional — initial BIGPROJECTS_ADMIN)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Cache / rate limiting (optional — unset fails open for local/CI; prefer Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Email (optional)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# File storage (optional)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# BOS integration (optional — empty disables inbound provisioning with HTTP 503)
BOS_API_KEY=

# API Swagger `/docs` (optional — off in production unless set to true)
# SWAGGER_ENABLED=true

# Analytics sampling for PROJECT_VIEW / APARTMENT_VIEW (0–1, default 1 = keep all)
# ANALYTICS_SAMPLE_RATE=1

# Cloud Run Sentry (optional — empty keeps API error tracking disabled)
SENTRY_DSN=

# Seed demo builder password
SEED_DEMO_BUILDER_PASSWORD=""

# Database seed (optional — initial ENTRANCE_STAFF for check-in)
SEED_ENTRANCE_EMAIL=""
SEED_ENTRANCE_PASSWORD=""

# Database seed (optional — PARTNER linked to Converse Bank demo)
SEED_PARTNER_EMAIL=""
SEED_PARTNER_PASSWORD=""
