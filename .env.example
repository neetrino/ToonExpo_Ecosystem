# Application
NODE_ENV="development"
PORT=4000
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Display FX (AMD per 1 foreign unit). Catalog prices stay AMD in DB; UI converts by locale.
# NEXT_PUBLIC_FX_AMD_PER_USD="390"
# NEXT_PUBLIC_FX_AMD_PER_RUB="4"
API_PROXY_TARGET=""
# Comma-separated list of allowed browser origins
CORS_ORIGINS="http://localhost:3000"
# LAN device testing (same machine + phone on Wi‑Fi):
# APP_URL="http://192.168.x.x:3000"
# NEXT_PUBLIC_API_URL=""
# API_PROXY_TARGET="http://127.0.0.1:4000"
# CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://192.168.x.x:3000"
# Also set apps/web next.config allowedDevOrigins to that IP.

# Database (Neon PostgreSQL)
# Runtime: pooled URL for apps/api
DATABASE_URL=""
# Migrations: direct (non-pooled) URL
DIRECT_URL=""

# Session auth (NestJS-owned sessions)
# Required; must be >=32 characters. Changing it invalidates all sessions and QR tokens.
SESSION_TOKEN_PEPPER=""
SESSION_COOKIE_NAME="toonexpo_session"
# Optional; defaults: idle 604800 (7d), absolute 2592000 (30d)
SESSION_IDLE_TTL_SECONDS=""
SESSION_ABSOLUTE_TTL_SECONDS=""
# Required; must be >=32 characters (HMAC for double-submit CSRF tokens)
CSRF_SECRET=""
# Optional override (default toonexpo_csrf)
CSRF_COOKIE_NAME=""

# Cache (reserved for future distributed rate-limit/cache; not read by code yet)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Email (Resend) — required in production
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# File storage (Cloudflare R2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
# Public CDN base for Next.js static/demo assets (same value as R2_PUBLIC_URL; safe to expose)
NEXT_PUBLIC_R2_PUBLIC_URL=""

# BOS integration (service-to-service; unset disables inbound provisioning with 503)
# Must be >=32 characters
BOS_API_KEY=""

# Seed accounts (local/dev only; falls back to ChangeMeAdmin123! when unset)
SEED_ADMIN_PASSWORD=""

# Error tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
