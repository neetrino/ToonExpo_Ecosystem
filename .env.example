# Copy to .env and fill in the values. Never commit .env.

# Application
NODE_ENV="development"
PORT=4000
APP_URL="http://localhost:3000"
# Web (apps/web) — API connectivity (env-only; no code change to switch modes)
# Mode A — same-origin proxy (staging + initial production on Vercel + Cloud Run):
#   API_PROXY_TARGET="https://toonexpo-api-xxxxx-ew.a.run.app"
#   NEXT_PUBLIC_API_URL=""   (leave empty/unset; browser calls /api/v1/* on the web origin)
# Mode B — direct browser → API (after api.toonexpo.com is mapped):
#   API_PROXY_TARGET=""      (unset)
#   NEXT_PUBLIC_API_URL="https://api.toonexpo.com"
# Local dev default below: direct to NestJS on :4000 without the proxy.
API_PROXY_TARGET=""
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Comma-separated list of allowed browser origins
CORS_ORIGINS="http://localhost:3000"

# Database (Neon PostgreSQL)
# Runtime: pooled URL for apps/api
DATABASE_URL=""
# Migrations: direct (non-pooled) URL
DIRECT_URL=""
# Approved starting points for pg pool (tune after load test; see docs/SETTINGS.md)
# Keep Cloud Run max_instances × DB_POOL_MAX under the Neon plan connection limit.
DB_POOL_MAX=8
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000

# Session auth (NestJS-owned sessions)
# Required; must be >=32 characters. Changing it invalidates all sessions and QR tokens.
SESSION_TOKEN_PEPPER=""
SESSION_COOKIE_NAME="toonexpo_session"
# Optional; defaults: idle 604800 (7d), absolute 2592000 (30d)
SESSION_IDLE_TTL_SECONDS=""
SESSION_ABSOLUTE_TTL_SECONDS=""
# Required; must be >=32 characters (HMAC for double-submit CSRF tokens)
CSRF_SECRET=""
# Optional override (default toonexpo_csrf)
CSRF_COOKIE_NAME=""

# Distributed rate limiting (optional; both required together; omit for in-memory local dev)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Email (Resend) — required in production
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# File storage (Cloudflare R2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# BOS integration (service-to-service; unset disables inbound provisioning with 503)
# Must be >=32 characters
BOS_API_KEY=""

# Web cache revalidation (optional; both required together for publish purge)
# Leave unset locally → Next Data Cache is TTL-only (max staleness 30–60 min).
# Owner generates REVALIDATE_SECRET (>=32 chars); same value on web + API.
# REVALIDATE_SECRET=""
# WEB_REVALIDATE_URL="http://localhost:3000/api/revalidate"
# WEB_REVALIDATE_SECRET=""

# Seed accounts (local/dev only; falls back to ChangeMeAdmin123! when unset)
SEED_ADMIN_PASSWORD=""

# Production bootstrap only — first platform_admin on an EMPTY database (never commit real values)
# PROD_ADMIN_EMAIL=""
# PROD_ADMIN_PASSWORD=""

# Error tracking (Sentry) — optional locally; leave empty to disable SDK init
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# CI-only: sourcemap upload token; lives in GitHub Secrets, not needed at runtime
SENTRY_AUTH_TOKEN=""
