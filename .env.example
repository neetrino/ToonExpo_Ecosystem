# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
# Browser talks to Nest via same-origin rewrite (`apps/web` → `/nest/*` → API_URL)
NEXT_PUBLIC_API_URL="/nest"

# Database (required by NestJS / Prisma — not required by frontend after full migration)
DATABASE_URL=""
# Optional: Neon non-pooled URL for migrations when DATABASE_URL uses a pooler
DIRECT_URL=""

# Authentication
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Optional: shared parent domain for cookies (e.g. .toonexpo.com). Leave empty with /nest rewrite.
# COOKIE_DOMAIN=
# lax (default, same-origin rewrite) | none (direct cross-site browser → Cloud Run)
# COOKIE_SAME_SITE=lax

# Database seed (optional — initial BIGPROJECTS_ADMIN)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Cache / rate limiting (optional — unset fails open for local/CI; prefer Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Email (optional)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# File storage (optional)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# BOS integration (optional — empty disables inbound provisioning with HTTP 503)
BOS_API_KEY=

# API Swagger `/docs` (optional — off in production unless set to true)
# SWAGGER_ENABLED=true

# Analytics sampling for PROJECT_VIEW / APARTMENT_VIEW (0–1, default 1 = keep all)
# ANALYTICS_SAMPLE_RATE=1

# Sentry (optional — empty keeps error tracking disabled; wire @sentry/nextjs when DSN exists)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Seed demo builder password
SEED_DEMO_BUILDER_PASSWORD=""

# Database seed (optional — initial ENTRANCE_STAFF for check-in)
SEED_ENTRANCE_EMAIL=""
SEED_ENTRANCE_PASSWORD=""

# Database seed (optional — PARTNER linked to Converse Bank demo)
SEED_PARTNER_EMAIL=""
SEED_PARTNER_PASSWORD=""
