# Application
NODE_ENV="development"
PORT=4000
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_PROXY_TARGET=""
# Comma-separated list of allowed browser origins
CORS_ORIGINS="http://localhost:3000"

# Database (Neon PostgreSQL)
# Runtime: pooled URL for apps/api
DATABASE_URL=""
# Migrations: direct (non-pooled) URL
DIRECT_URL=""

# Session auth (NestJS-owned sessions)
# Required; must be >=32 characters. Changing it invalidates all sessions and QR tokens.
SESSION_TOKEN_PEPPER=""
SESSION_COOKIE_NAME="toonexpo_session"
# Optional; defaults: idle 604800 (7d), absolute 2592000 (30d)
SESSION_IDLE_TTL_SECONDS=""
SESSION_ABSOLUTE_TTL_SECONDS=""
# Required; must be >=32 characters (HMAC for double-submit CSRF tokens)
CSRF_SECRET=""
# Optional override (default toonexpo_csrf)
CSRF_COOKIE_NAME=""

# Cache (reserved for future distributed rate-limit/cache; not read by code yet)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Email (Resend) — required in production
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# File storage (Cloudflare R2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# BOS integration (service-to-service; unset disables inbound provisioning with 503)
# Must be >=32 characters
BOS_API_KEY=""

# Seed accounts (local/dev only; falls back to ChangeMeAdmin123! when unset)
SEED_ADMIN_PASSWORD=""

# Error tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
