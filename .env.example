# Application
NODE_ENV="development"
PORT=4000
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
DEFAULT_LOCALE="en"
SUPPORTED_LOCALES="hy,ru,en"

# Database (Neon PostgreSQL)
# Runtime: pooled DML-only URL for apps/api
DATABASE_URL=""
# Migrations only: direct (non-pooled) owner URL
DIRECT_URL=""
DATABASE_CONNECTION_LIMIT=""
DATABASE_POOL_TIMEOUT=""

# Authentication (NestJS-owned sessions)
# SESSION_TOKEN_PEPPER must be ≥32 characters (required)
SESSION_TOKEN_PEPPER=""
SESSION_COOKIE_NAME="toonexpo_session"
# Idle TTL seconds (default 604800 = 7 days) — ADAPTIVE
SESSION_IDLE_TTL_SECONDS=""
# Absolute TTL seconds (default 2592000 = 30 days) — ADAPTIVE
SESSION_ABSOLUTE_TTL_SECONDS=""
# CSRF_SECRET must be ≥32 characters (required; HMAC for double-submit tokens)
CSRF_SECRET=""
# Optional override (default toonexpo_csrf)
CSRF_COOKIE_NAME=""
CORS_ORIGINS="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# BOS integration (service-to-service; unset disables inbound provisioning endpoints)
# Generate a random string ≥32 characters for production
BOS_API_KEY=""

# Seed accounts (local/dev only; used by packages/db prisma seed)
# Defaults to ChangeMeAdmin123! when unset — never use the default in production
SEED_ADMIN_PASSWORD=""

# File storage (Cloudflare R2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Error tracking (Sentry)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Figma (optional local tooling)
FIGMA_ACCESS_TOKEN=""
