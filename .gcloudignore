# Cloud Build source upload only. Docker still uses .dockerignore for the build context.
# Keep in sync with .dockerignore for heavy paths so upload stays small.

# Dependencies and build output
node_modules
**/node_modules
.next
**/.next
dist
**/dist
build
**/build
coverage
**/coverage
.turbo
**/.turbo
*.tsbuildinfo
**/*.tsbuildinfo

# Environment and secrets
.env
.env.*
!.env.example

# Version control and IDE
.git
**/.git
.idea
.vscode
.cursor
.DS_Store
Thumbs.db

# CI, hooks, local tooling
.github
.husky
.load
load
scripts

# Docs (not needed to build the API image)
docs
*.md
!README.md
AGENTS.md
LICENSE

# Web app source (API image does not need it; keep package.json for workspace graph)
apps/web/**
!apps/web/package.json

# Tests
**/test
**/*.spec.ts
**/*.test.ts
**/*.e2e-spec.ts

# Prisma generated client (rebuilt during image build)
packages/db/src/generated

# OS, logs, caches
*.log
tmp
temp
.cache
**/playwright-report
**/test-results
