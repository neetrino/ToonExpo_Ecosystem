generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Exclusive platform account type (one user = one type).
enum AccountType {
  buyer
  platform_admin
  entrance_staff
  company_member
}

enum UserStatus {
  invited
  active
  inactive
  blocked
}

/// Business organization type (not a user account type).
enum CompanyType {
  builder
  partner
  bank
  service
}

enum CompanyStatus {
  active
  inactive
  pending
}

enum CompanySource {
  self_registered
  admin
  bos
}

/// Role inside a company (v1). Applies when accountType = company_member.
enum CompanyMemberRole {
  company_admin
  member
}

enum CompanyMemberStatus {
  active
  inactive
  removed
}

/// Purpose of a one-time account access token (set-password / invite / reset).
enum AccountAccessTokenPurpose {
  set_password
  invite
  password_reset
}

model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  phone         String?
  /// Null until set-password (provisioned / invited users).
  passwordHash  String?     @map("password_hash")
  /// Exclusive account type used by NestJS RBAC.
  accountType   AccountType @default(buyer) @map("account_type")
  status        UserStatus  @default(active)
  defaultLocale String?     @map("default_locale")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  sessions           Session[]
  buyerProfile       BuyerProfile?
  companyMembership  CompanyMember?
  invitedMemberships CompanyMember[]      @relation("CompanyMemberInviter")
  accessTokens       AccountAccessToken[]
  createdRequests    Request[]            @relation("RequestCreatedBy")
  assignedCrmDeals   CrmDeal[]            @relation("CrmDealAssignee")
  createdCrmDeals    CrmDeal[]            @relation("CrmDealCreatedBy")
  crmNotes           CrmNote[]
  createdCrmActivities CrmFollowUpActivity[] @relation("CrmActivityCreatedBy")
  assignedCrmActivities CrmFollowUpActivity[] @relation("CrmActivityAssignee")
  createdApartmentLinks CrmDealApartmentLink[] @relation("CrmApartmentLinkCreatedBy")

  @@index([accountType])
  @@map("users")
}

model Session {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  tokenHash         String    @unique @map("token_hash")
  idleExpiresAt     DateTime  @map("idle_expires_at")
  absoluteExpiresAt DateTime  @map("absolute_expires_at")
  lastSeenAt        DateTime? @map("last_seen_at")
  revokedAt         DateTime? @map("revoked_at")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([idleExpiresAt])
  @@index([absoluteExpiresAt])
  @@map("sessions")
}

model BuyerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  name      String
  phone     String
  email     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCode   QrCode?
  requests Request[]
  crmDeals CrmDeal[]

  @@map("buyer_profiles")
}

/// Permanent buyer QR lifecycle status.
enum QrCodeStatus {
  active
  inactive
  blocked
}

/// Who/what context triggered a QR resolve.
enum QrScanContext {
  builder_scan
  entrance_checkin
  buyer_self_view
  unknown
}

/// Outcome of a QR resolve attempt.
enum QrScanResultStatus {
  resolved
  invalid
  blocked
  unauthorized
  error
}

/// One permanent opaque QR token per buyer profile.
model QrCode {
  id             String       @id @default(cuid())
  buyerProfileId String       @unique @map("buyer_profile_id")
  /// SHA-256(pepper:token) — resolve lookups never use the raw token column.
  tokenHash      String       @unique @map("token_hash")
  /// AES-256-GCM blob of the raw token for permanent My QR redisplay.
  tokenEncrypted String       @map("token_encrypted")
  status         QrCodeStatus @default(active)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  regeneratedAt  DateTime?    @map("regenerated_at")
  blockedAt      DateTime?    @map("blocked_at")
  blockedReason  String?      @map("blocked_reason")

  buyerProfile BuyerProfile  @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  scanEvents   QrScanEvent[]

  @@index([status])
  @@map("qr_codes")
}

/// Technical scan/resolve log for a buyer QR.
model QrScanEvent {
  id               String             @id @default(cuid())
  qrCodeId         String             @map("qr_code_id")
  buyerProfileId   String             @map("buyer_profile_id")
  scannerUserId    String?            @map("scanner_user_id")
  scannerCompanyId String?            @map("scanner_company_id")
  scannerRole      String?            @map("scanner_role")
  scanContext      QrScanContext      @map("scan_context")
  resultStatus     QrScanResultStatus @map("result_status")
  ipAddress        String?            @map("ip_address")
  userAgent        String?            @map("user_agent")
  createdAt        DateTime           @default(now()) @map("created_at")

  qrCode   QrCode    @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  requests Request[]

  @@index([qrCodeId])
  @@index([buyerProfileId])
  @@index([scannerUserId])
  @@index([scannerCompanyId])
  @@index([createdAt])
  @@map("qr_scan_events")
}

model Company {
  id           String        @id @default(cuid())
  name         String
  /// Public builder/company blurb (Armenian canonical; localized via Translation).
  description  String?
  type         CompanyType
  status       CompanyStatus @default(pending)
  source       CompanySource
  bosCompanyId String?       @map("bos_company_id")
  /// Optional public logo (MediaAsset URL metadata only in this sprint).
  logoMediaId  String?       @map("logo_media_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  members     CompanyMember[]
  logoMedia   MediaAsset?     @relation("CompanyLogo", fields: [logoMediaId], references: [id], onDelete: SetNull)
  ownedMedia  MediaAsset[]    @relation("MediaOwnerCompany")
  projects    Project[]
  requests    Request[]
  crmDeals    CrmDeal[]

  @@index([type])
  @@index([status])
  @@map("companies")
}

model CompanyMember {
  id              String              @id @default(cuid())
  companyId       String              @map("company_id")
  userId          String              @unique @map("user_id")
  role            CompanyMemberRole
  status          CompanyMemberStatus @default(active)
  invitedByUserId String?             @map("invited_by_user_id")
  joinedAt        DateTime?           @map("joined_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("CompanyMemberInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([role])
  @@map("company_members")
}

/// One-time set-password / invite tokens (schema only; issue/accept in provisioning sprint).
model AccountAccessToken {
  id        String                     @id @default(cuid())
  userId    String                     @map("user_id")
  purpose   AccountAccessTokenPurpose
  tokenHash String                     @unique @map("token_hash")
  expiresAt DateTime                   @map("expires_at")
  usedAt    DateTime?                  @map("used_at")
  createdAt DateTime                   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("account_access_tokens")
}

/// Public/draft/archived gate for catalog entities.
enum PublicationStatus {
  draft
  published
  archived
}

/// Sellable apartment inventory status (Constructor CRM is SoT after CRM is live).
enum ApartmentSalesStatus {
  available
  reserved
  sold
}

/// How apartment price is shown on public surfaces.
enum PriceVisibility {
  public
  by_request
  visible_after_login
}

/// Origin of the current apartment sales status.
enum CrmStatusSource {
  manual
  crm
  import
}

/// Shared media metadata (file upload pipeline comes later; URL fields only).
enum MediaAssetType {
  image
  video
  document
  other
}

model MediaAsset {
  id                String         @id @default(cuid())
  ownerCompanyId    String?        @map("owner_company_id")
  relatedEntityType String?        @map("related_entity_type")
  relatedEntityId   String?        @map("related_entity_id")
  type              MediaAssetType
  fileUrl           String         @map("file_url")
  thumbnailUrl      String?        @map("thumbnail_url")
  title             String?
  altText           String?        @map("alt_text")
  sortOrder         Int            @default(0) @map("sort_order")
  uploadedByUserId  String?        @map("uploaded_by_user_id")
  createdAt         DateTime       @default(now()) @map("created_at")

  ownerCompany   Company?   @relation("MediaOwnerCompany", fields: [ownerCompanyId], references: [id], onDelete: SetNull)
  companyLogos   Company[]  @relation("CompanyLogo")
  projectCovers  Project[]  @relation("ProjectCover")
  buildingCovers Building[] @relation("BuildingCover")
  floorPlans     Floor[]    @relation("FloorPlan")
  apartmentPlans Apartment[] @relation("ApartmentPlan")

  @@index([ownerCompanyId])
  @@index([relatedEntityType, relatedEntityId])
  @@map("media_assets")
}

model Project {
  id                  String            @id @default(cuid())
  builderCompanyId    String            @map("builder_company_id")
  name                String
  slug                String            @unique
  publicationStatus   PublicationStatus @default(draft) @map("publication_status")
  shortDescription    String?           @map("short_description")
  fullDescription     String?           @map("full_description")
  locationText        String?           @map("location_text")
  address             String?
  city                String?
  district            String?
  latitude            Decimal?          @db.Decimal(10, 7)
  longitude           Decimal?          @db.Decimal(10, 7)
  coverMediaId        String?           @map("cover_media_id")
  projectType         String?           @map("project_type")
  constructionStatus  String?           @map("construction_status")
  completionDate      DateTime?         @map("completion_date") @db.Date
  amenities           Json?
  nearbyPlaces        Json?             @map("nearby_places")
  createdByUserId     String?           @map("created_by_user_id")
  updatedByUserId     String?           @map("updated_by_user_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  builderCompany Company     @relation(fields: [builderCompanyId], references: [id], onDelete: Restrict)
  coverMedia     MediaAsset? @relation("ProjectCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  buildings      Building[]
  apartments     Apartment[]
  requests       Request[]
  crmDeals       CrmDeal[]

  @@index([builderCompanyId])
  @@index([publicationStatus])
  @@index([city])
  @@map("projects")
}

model Building {
  id                String            @id @default(cuid())
  projectId         String            @map("project_id")
  name              String
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  description       String?
  displayOrder      Int               @default(0) @map("display_order")
  floorsCount       Int?              @map("floors_count")
  coverMediaId      String?           @map("cover_media_id")
  internalCode      String?           @map("internal_code")
  createdByUserId   String?           @map("created_by_user_id")
  updatedByUserId   String?           @map("updated_by_user_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coverMedia MediaAsset? @relation("BuildingCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  floors     Floor[]
  apartments Apartment[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([publicationStatus])
  @@map("buildings")
}

model Floor {
  id                String            @id @default(cuid())
  buildingId        String            @map("building_id")
  number            Int
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  name              String?
  displayLabel      String?           @map("display_label")
  displayOrder      Int               @default(0) @map("display_order")
  floorplanMediaId  String?           @map("floorplan_media_id")
  description       String?
  createdByUserId   String?           @map("created_by_user_id")
  updatedByUserId   String?           @map("updated_by_user_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  building       Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floorplanMedia MediaAsset? @relation("FloorPlan", fields: [floorplanMediaId], references: [id], onDelete: SetNull)
  apartments     Apartment[]

  @@unique([buildingId, number])
  @@index([buildingId])
  @@index([publicationStatus])
  @@map("floors")
}

model Apartment {
  id                      String               @id @default(cuid())
  projectId               String               @map("project_id")
  buildingId              String               @map("building_id")
  floorId                 String               @map("floor_id")
  number                  String
  salesStatus             ApartmentSalesStatus @default(available) @map("sales_status")
  publicationStatus       PublicationStatus    @default(draft) @map("publication_status")
  rooms                   Int?
  bedrooms                Int?
  bathrooms               Int?
  areaTotal               Decimal?             @map("area_total") @db.Decimal(10, 2)
  areaLiving              Decimal?             @map("area_living") @db.Decimal(10, 2)
  balconyArea             Decimal?             @map("balcony_area") @db.Decimal(10, 2)
  /// Amount in `priceCurrency` major units (e.g. AMD). ADAPTIVE: confirm minor-unit storage later.
  price                   Decimal?             @db.Decimal(14, 2)
  priceCurrency           String               @default("AMD") @map("price_currency")
  priceVisibility         PriceVisibility      @default(public) @map("price_visibility")
  description             String?
  planMediaId             String?              @map("plan_media_id")
  matterportUrl           String?              @map("matterport_url")
  external3dUrl           String?              @map("external_3d_url")
  orientation             String?
  viewType                String?              @map("view_type")
  features                Json?
  crmStatusSource         CrmStatusSource      @default(manual) @map("crm_status_source")
  activeCrmDealId         String?              @map("active_crm_deal_id")
  reservedUntil           DateTime?            @map("reserved_until")
  lastStatusChangedAt     DateTime?            @map("last_status_changed_at")
  lastStatusChangedByUserId String?            @map("last_status_changed_by_user_id")
  internalCode            String?              @map("internal_code")
  importExternalId        String?              @map("import_external_id")
  createdByUserId         String?              @map("created_by_user_id")
  updatedByUserId         String?              @map("updated_by_user_id")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  project       Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  building      Building                  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor         Floor                     @relation(fields: [floorId], references: [id], onDelete: Cascade)
  planMedia     MediaAsset?               @relation("ApartmentPlan", fields: [planMediaId], references: [id], onDelete: SetNull)
  statusHistory ApartmentStatusHistory[]
  requests      Request[]
  dealLinks     CrmDealApartmentLink[]

  @@unique([floorId, number])
  @@index([projectId])
  @@index([buildingId])
  @@index([floorId])
  @@index([publicationStatus])
  @@index([salesStatus])
  @@index([price])
  @@index([rooms])
  @@index([publicationStatus, salesStatus])
  @@index([projectId, publicationStatus])
  @@map("apartments")
}

/// Audit trail for apartment sales status changes (price/publication history can extend later).
model ApartmentStatusHistory {
  id              String                @id @default(cuid())
  apartmentId     String                @map("apartment_id")
  previousStatus  ApartmentSalesStatus? @map("previous_status")
  newStatus       ApartmentSalesStatus  @map("new_status")
  reason          String?
  changedByUserId String?               @map("changed_by_user_id")
  linkedDealId    String?               @map("linked_deal_id")
  createdAt       DateTime              @default(now()) @map("created_at")

  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId])
  @@index([createdAt])
  @@map("apartment_status_history")
}

/// Localized public catalog text (hy / ru / en). Scalar columns remain Armenian fallbacks.
model Translation {
  id              String   @id @default(cuid())
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  fieldName       String   @map("field_name")
  locale          String
  value           String
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([entityType, entityId, fieldName, locale])
  @@index([entityType, entityId])
  @@index([locale])
  @@map("translations")
}

/// Canonical deal/request creation source (unified intake use case).
enum RequestSource {
  buyer_project_request
  builder_buyer_qr_scan
  manual_builder_entry
  event_interaction
}

/// Intake request lifecycle (deal owns the sales pipeline).
enum RequestStatus {
  submitted
  attached
  cancelled
}

/// Constructor CRM pipeline status (docs: CRM-Pipeline-And-Statuses).
enum CrmDealStatus {
  new_request
  assigned
  contacted
  follow_up_needed
  apartment_selected
  reserved
  converted
  closed
  lost
}

enum CrmDealApartmentLinkType {
  interest
  selected
  reserved
  sold
}

enum CrmNoteVisibility {
  internal
}

enum CrmActivityType {
  call
  email
  meeting
  send_offer
  follow_up
  status_update
  other
}

enum CrmActivityStatus {
  planned
  done
  cancelled
}

/// Intake request from buyer/QR/manual sources. Many requests may attach to one deal.
model Request {
  id               String         @id @default(cuid())
  /// Null for manual CRM-only contacts without a registered buyer.
  buyerProfileId   String?        @map("buyer_profile_id")
  builderCompanyId String         @map("builder_company_id")
  projectId        String?        @map("project_id")
  apartmentId      String?        @map("apartment_id")
  source           RequestSource
  status           RequestStatus  @default(submitted)
  note             String?
  scanEventId      String?        @map("scan_event_id")
  createdByUserId  String?        @map("created_by_user_id")
  crmDealId        String?        @map("crm_deal_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  buyerProfile   BuyerProfile? @relation(fields: [buyerProfileId], references: [id], onDelete: SetNull)
  builderCompany Company       @relation(fields: [builderCompanyId], references: [id], onDelete: Restrict)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  apartment      Apartment?    @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
  scanEvent      QrScanEvent?  @relation(fields: [scanEventId], references: [id], onDelete: SetNull)
  createdBy      User?         @relation("RequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  crmDeal        CrmDeal?      @relation(fields: [crmDealId], references: [id], onDelete: SetNull)
  primaryForDeals CrmDeal[]    @relation("CrmDealPrimaryRequest")

  @@index([buyerProfileId])
  @@index([builderCompanyId])
  @@index([projectId])
  @@index([apartmentId])
  @@index([source])
  @@index([status])
  @@index([crmDealId])
  @@index([scanEventId])
  @@index([createdAt])
  @@map("requests")
}

/// Constructor CRM work item (one open deal per builder+buyer via intake dedup).
model CrmDeal {
  id               String        @id @default(cuid())
  companyId        String        @map("company_id")
  buyerProfileId   String?       @map("buyer_profile_id")
  primaryRequestId String?       @map("primary_request_id")
  source           RequestSource
  status           CrmDealStatus @default(new_request)
  title            String?
  message          String?
  /// Manual entry contact fields when no BuyerProfile is linked yet.
  contactName      String?       @map("contact_name")
  contactPhone     String?       @map("contact_phone")
  contactEmail     String?       @map("contact_email")
  assignedUserId   String?       @map("assigned_user_id")
  createdByUserId  String?       @map("created_by_user_id")
  lostReason       String?       @map("lost_reason")
  lastActivityAt   DateTime?     @map("last_activity_at")
  nextFollowUpAt   DateTime?     @map("next_follow_up_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  buyerProfile   BuyerProfile?           @relation(fields: [buyerProfileId], references: [id], onDelete: SetNull)
  primaryRequest Request?                @relation("CrmDealPrimaryRequest", fields: [primaryRequestId], references: [id], onDelete: SetNull)
  assignedUser   User?                   @relation("CrmDealAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy      User?                   @relation("CrmDealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  projectId      String?                 @map("project_id")
  project        Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requests       Request[]
  apartmentLinks CrmDealApartmentLink[]
  notes          CrmNote[]
  activities     CrmFollowUpActivity[]

  @@index([companyId])
  @@index([buyerProfileId])
  @@index([status])
  @@index([source])
  @@index([projectId])
  @@index([assignedUserId])
  @@index([updatedAt])
  @@index([companyId, buyerProfileId, status])
  @@map("crm_deals")
}

model CrmDealApartmentLink {
  id                         String                    @id @default(cuid())
  crmDealId                  String                    @map("crm_deal_id")
  apartmentId                String                    @map("apartment_id")
  linkType                   CrmDealApartmentLinkType  @default(interest) @map("link_type")
  isPrimary                  Boolean                   @default(false) @map("is_primary")
  apartmentSalesStatusAtLink ApartmentSalesStatus?     @map("apartment_sales_status_at_link")
  priceAtLink                Decimal?                  @map("price_at_link") @db.Decimal(14, 2)
  priceVisibilityAtLink      PriceVisibility?          @map("price_visibility_at_link")
  createdByUserId            String?                   @map("created_by_user_id")
  createdAt                  DateTime                  @default(now()) @map("created_at")

  crmDeal         CrmDeal    @relation(fields: [crmDealId], references: [id], onDelete: Cascade)
  apartment       Apartment  @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  createdBy       User?      @relation("CrmApartmentLinkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([crmDealId, apartmentId])
  @@index([crmDealId])
  @@index([apartmentId])
  @@map("crm_deal_apartment_links")
}

model CrmNote {
  id           String            @id @default(cuid())
  crmDealId    String            @map("crm_deal_id")
  authorUserId String            @map("author_user_id")
  body         String
  visibility   CrmNoteVisibility @default(internal)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  crmDeal CrmDeal @relation(fields: [crmDealId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([crmDealId])
  @@index([authorUserId])
  @@index([createdAt])
  @@map("crm_notes")
}

model CrmFollowUpActivity {
  id              String            @id @default(cuid())
  crmDealId       String            @map("crm_deal_id")
  type            CrmActivityType
  title           String
  description     String?
  dueAt           DateTime?         @map("due_at")
  status          CrmActivityStatus @default(planned)
  assignedUserId  String?           @map("assigned_user_id")
  createdByUserId String            @map("created_by_user_id")
  completedAt     DateTime?         @map("completed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  crmDeal      CrmDeal @relation(fields: [crmDealId], references: [id], onDelete: Cascade)
  assignedUser User?   @relation("CrmActivityAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy    User    @relation("CrmActivityCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([crmDealId])
  @@index([status])
  @@index([dueAt])
  @@index([assignedUserId])
  @@map("crm_follow_up_activities")
}
