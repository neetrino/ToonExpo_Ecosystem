generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum PlatformRole {
  BIGPROJECTS_ADMIN
  BUILDER
  PARTNER
  BUYER
  ENTRANCE_STAFF
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApartmentStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum DealStage {
  NEW_REQUEST
  ASSIGNED
  CONTACTED
  FOLLOW_UP_NEEDED
  APARTMENT_SELECTED
  RESERVED
  CONVERTED
  CLOSED
  LOST
}

enum RequestSource {
  PROJECT_PAGE
  APARTMENT_PAGE
  BUILDER_QR_SCAN
  MANUAL_BUILDER_ENTRY
  EVENT_INTERACTION
}

enum DealActivityType {
  COMMENT
  FOLLOW_UP
  STATUS_CHANGE
}

enum QrScanPurpose {
  BUILDER_SCAN
  ENTRANCE_CHECKIN
  BUYER_SELF_VIEW
  UNKNOWN
}


model User {
  id                String          @id @default(cuid())
  email             String          @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  phone             String?
  passwordHash      String?
  role              PlatformRole    @default(BUYER)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  accounts          Account[]
  sessions          Session[]
  buyerProfile      BuyerProfile?
  members           CompanyMember[]
  dealsAsBuyer      Deal[]          @relation("DealBuyer")
  dealsAssigned     Deal[]          @relation("DealAssignee")
  dealsCreated      Deal[]          @relation("DealCreator")
  dealActivities    DealActivity[]
  qrScanLogs        QrScanLog[]
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BuyerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCode    QrCode?
}

model QrCode {
  id             String       @id @default(cuid())
  buyerProfileId String       @unique
  /// Opaque random token (no PII). Stored so the buyer can re-display their QR
  /// without rotating on every view. tokenHash remains the lookup key.
  /// Privacy: 05-Privacy-And-Security forbids encoding PII in the payload, not
  /// storing the opaque secret server-side behind buyer auth.
  token          String       @unique
  tokenHash      String       @unique
  createdAt      DateTime     @default(now())
  revokedAt      DateTime?
  buyerProfile   BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  scanLogs       QrScanLog[]
}

model Company {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  members   CompanyMember[]
  projects  Project[]
  deals     Deal[]
  qrScanLogs QrScanLog[]
}


model CompanyMember {
  id        String       @id @default(cuid())
  companyId String
  userId    String
  role      PlatformRole
  createdAt DateTime     @default(now())
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
}

model Project {
  id          String            @id @default(cuid())
  companyId   String
  name        String
  slug        String
  description String?           @db.Text
  city        String?
  address     String?
  status      PublicationStatus @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  buildings   Building[]
  media       MediaAsset[]
  deals       Deal[]

  @@unique([companyId, slug])
  @@index([status])
}


model Building {
  id        String   @id @default(cuid())
  projectId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  floors    Floor[]

  @@index([projectId])
}

model Floor {
  id         String      @id @default(cuid())
  buildingId String
  name       String
  level      Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  building   Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  apartments Apartment[]

  @@unique([buildingId, level])
}

model Apartment {
  id        String          @id @default(cuid())
  floorId   String
  code      String
  status    ApartmentStatus @default(AVAILABLE)
  areaSqm   Float?
  rooms     Int?
  priceAmd  Int?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  floor     Floor           @relation(fields: [floorId], references: [id], onDelete: Cascade)
  media     MediaAsset[]
  dealLinks DealApartment[]

  @@unique([floorId, code])
  @@index([status])
}

// Exactly one of projectId or apartmentId must be set — enforced at application layer, not DB.
model MediaAsset {
  id          String     @id @default(cuid())
  url         String
  alt         String?
  sortOrder   Int        @default(0)
  projectId   String?
  apartmentId String?
  createdAt   DateTime   @default(now())
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  apartment   Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([apartmentId])
}

// Company-scoped CRM work item. Sources: public request, QR scan, or manual builder entry.
// App layer must require ≥1 DealApartment before stage RESERVED or CONVERTED.
model Deal {
  id               String        @id @default(cuid())
  companyId        String
  stage            DealStage     @default(NEW_REQUEST)
  source           RequestSource
  buyerUserId      String?
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  title            String?
  message          String?       @db.Text
  assignedUserId   String?
  createdByUserId  String?
  projectId        String?
  lastActivityAt   DateTime?
  nextFollowUpAt   DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  buyerUser        User?         @relation("DealBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  assignedUser     User?         @relation("DealAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdByUser    User?         @relation("DealCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  apartments       DealApartment[]
  activities       DealActivity[]

  @@index([companyId, stage])
  @@index([buyerUserId])
  @@index([createdAt])
}

model DealApartment {
  id          String    @id @default(cuid())
  dealId      String
  apartmentId String
  createdAt   DateTime  @default(now())
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@unique([dealId, apartmentId])
  @@index([dealId])
  @@index([apartmentId])
}

model DealActivity {
  id           String           @id @default(cuid())
  dealId       String
  authorUserId String?
  type         DealActivityType
  body         String           @db.Text
  createdAt    DateTime         @default(now())
  deal         Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorUser   User?            @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([dealId])
}

model QrScanLog {
  id              String        @id @default(cuid())
  qrCodeId        String
  scannedByUserId String
  companyId       String?
  purpose         QrScanPurpose @default(UNKNOWN)
  scannedAt       DateTime      @default(now())
  qrCode          QrCode        @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  scannedByUser   User          @relation(fields: [scannedByUserId], references: [id], onDelete: Cascade)
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([qrCodeId])
  @@index([scannedByUserId])
  @@index([companyId])
  @@index([scannedAt])
}
