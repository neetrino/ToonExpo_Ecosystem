generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Exclusive platform account type (one user = one type).
enum AccountType {
  buyer
  platform_admin
  entrance_staff
  company_member
}

enum UserStatus {
  invited
  active
  inactive
  blocked
}

/// Business organization type (not a user account type).
enum CompanyType {
  builder
  partner
  bank
  service
}

enum CompanyStatus {
  active
  inactive
  pending
}

enum CompanySource {
  self_registered
  admin
  bos
}

/// Role inside a company (v1). Applies when accountType = company_member.
enum CompanyMemberRole {
  company_admin
  member
}

enum CompanyMemberStatus {
  active
  inactive
  removed
}

/// Purpose of a one-time account access token (set-password / invite / reset).
enum AccountAccessTokenPurpose {
  set_password
  invite
  password_reset
}

model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  phone         String?
  /// Null until set-password (provisioned / invited users).
  passwordHash  String?     @map("password_hash")
  /// Exclusive account type used by NestJS RBAC.
  accountType   AccountType @default(buyer) @map("account_type")
  status        UserStatus  @default(active)
  defaultLocale String?     @map("default_locale")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  sessions           Session[]
  buyerProfile       BuyerProfile?
  companyMembership  CompanyMember?
  invitedMemberships CompanyMember[]      @relation("CompanyMemberInviter")
  accessTokens       AccountAccessToken[]
  createdRequests    Request[]            @relation("RequestCreatedBy")
  assignedCrmDeals   CrmDeal[]            @relation("CrmDealAssignee")
  createdCrmDeals    CrmDeal[]            @relation("CrmDealCreatedBy")
  crmNotes           CrmNote[]
  createdCrmActivities CrmFollowUpActivity[] @relation("CrmActivityCreatedBy")
  assignedCrmActivities CrmFollowUpActivity[] @relation("CrmActivityAssignee")
  createdApartmentLinks CrmDealApartmentLink[] @relation("CrmApartmentLinkCreatedBy")
  evaluatedReadinessAssessments ReadinessAssessment[] @relation("ReadinessAssessmentEvaluator")
  evaluatedReadinessScores      ReadinessScore[]      @relation("ReadinessScoreEvaluator")
  createdReadinessRecommendations ReadinessRecommendation[] @relation("ReadinessRecommendationCreator")
  createdReadinessRequiredActions ReadinessRequiredAction[] @relation("ReadinessRequiredActionCreator")
  authoredReadinessInternalNotes  ReadinessInternalNote[]   @relation("ReadinessInternalNoteAuthor")
  createdBankOffers               BankOffer[]               @relation("BankOfferCreator")
  updatedBankOffers               BankOffer[]               @relation("BankOfferUpdater")
  createdServiceProviders         ServiceProvider[]         @relation("ServiceProviderCreator")
  updatedServiceProviders         ServiceProvider[]         @relation("ServiceProviderUpdater")
  createdVenueMaps                VenueMap[]                @relation("VenueMapCreator")
  updatedVenueMaps                VenueMap[]                @relation("VenueMapUpdater")
  createdVisualMapCanvases        VisualMapCanvas[]         @relation("VisualMapCanvasCreator")
  updatedVisualMapCanvases        VisualMapCanvas[]         @relation("VisualMapCanvasUpdater")
  createdVisualHotspots           VisualHotspot[]           @relation("VisualHotspotCreator")
  updatedVisualHotspots           VisualHotspot[]           @relation("VisualHotspotUpdater")
  checkInRecords                  CheckInRecord[]           @relation("CheckInStaff")

  @@index([accountType])
  @@map("users")
}

model Session {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  tokenHash         String    @unique @map("token_hash")
  idleExpiresAt     DateTime  @map("idle_expires_at")
  absoluteExpiresAt DateTime  @map("absolute_expires_at")
  lastSeenAt        DateTime? @map("last_seen_at")
  revokedAt         DateTime? @map("revoked_at")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([idleExpiresAt])
  @@index([absoluteExpiresAt])
  @@map("sessions")
}

model BuyerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  name      String
  phone     String
  email     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCode         QrCode?
  requests       Request[]
  crmDeals       CrmDeal[]
  checkInRecords CheckInRecord[]
  favorites      BuyerFavorite[]

  @@map("buyer_profiles")
}

/// Polymorphic favorite target (v1: project | apartment).
enum FavoriteTargetType {
  project
  apartment

  @@map("favorite_target_type")
}

/// Buyer-saved project or apartment. targetId has no FK so domain deletes are not blocked.
model BuyerFavorite {
  id             String             @id @default(cuid())
  buyerProfileId String             @map("buyer_profile_id")
  targetType     FavoriteTargetType @map("target_type")
  targetId       String             @map("target_id")
  createdAt      DateTime           @default(now()) @map("created_at")

  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)

  @@unique([buyerProfileId, targetType, targetId])
  @@index([buyerProfileId, createdAt])
  @@map("buyer_favorites")
}

/// Permanent buyer QR lifecycle status.
enum QrCodeStatus {
  active
  inactive
  blocked
}

/// Who/what context triggered a QR resolve.
enum QrScanContext {
  builder_scan
  entrance_checkin
  buyer_self_view
  unknown
}

/// Outcome of a QR resolve attempt.
enum QrScanResultStatus {
  resolved
  invalid
  blocked
  unauthorized
  error
}

/// One permanent opaque QR token per buyer profile.
model QrCode {
  id             String       @id @default(cuid())
  buyerProfileId String       @unique @map("buyer_profile_id")
  /// SHA-256(pepper:token) — resolve lookups never use the raw token column.
  tokenHash      String       @unique @map("token_hash")
  /// AES-256-GCM blob of the raw token for permanent My QR redisplay.
  tokenEncrypted String       @map("token_encrypted")
  status         QrCodeStatus @default(active)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  regeneratedAt  DateTime?    @map("regenerated_at")
  blockedAt      DateTime?    @map("blocked_at")
  blockedReason  String?      @map("blocked_reason")

  buyerProfile   BuyerProfile    @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  scanEvents     QrScanEvent[]
  checkInRecords CheckInRecord[]

  @@index([status])
  @@map("qr_codes")
}

/// Technical scan/resolve log for a buyer QR.
model QrScanEvent {
  id               String             @id @default(cuid())
  qrCodeId         String             @map("qr_code_id")
  buyerProfileId   String             @map("buyer_profile_id")
  scannerUserId    String?            @map("scanner_user_id")
  scannerCompanyId String?            @map("scanner_company_id")
  scannerRole      String?            @map("scanner_role")
  scanContext      QrScanContext      @map("scan_context")
  resultStatus     QrScanResultStatus @map("result_status")
  ipAddress        String?            @map("ip_address")
  userAgent        String?            @map("user_agent")
  createdAt        DateTime           @default(now()) @map("created_at")

  qrCode         QrCode          @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  requests       Request[]
  checkInRecords CheckInRecord[]

  @@index([qrCodeId])
  @@index([buyerProfileId])
  @@index([scannerUserId])
  @@index([scannerCompanyId])
  @@index([createdAt])
  @@map("qr_scan_events")
}

model Company {
  id           String        @id @default(cuid())
  name         String
  /// Public builder/company blurb (Armenian canonical; localized via Translation).
  description  String?
  type         CompanyType
  status       CompanyStatus @default(pending)
  source       CompanySource
  bosCompanyId String?       @map("bos_company_id")
  /// Optional public logo (MediaAsset URL metadata only in this sprint).
  logoMediaId  String?       @map("logo_media_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  members     CompanyMember[]
  logoMedia   MediaAsset?     @relation("CompanyLogo", fields: [logoMediaId], references: [id], onDelete: SetNull)
  ownedMedia       MediaAsset[]      @relation("MediaOwnerCompany")
  visualMapCanvases VisualMapCanvas[]
  projects    Project[]
  requests             Request[]
  crmDeals             CrmDeal[]
  readinessAssessments ReadinessAssessment[]
  partnerCompany       PartnerCompany?
  boothAssignments     BoothAssignment[]

  @@unique([bosCompanyId])
  @@index([type])
  @@index([status])
  @@map("companies")
}

model CompanyMember {
  id              String              @id @default(cuid())
  companyId       String              @map("company_id")
  userId          String              @unique @map("user_id")
  role            CompanyMemberRole
  status          CompanyMemberStatus @default(active)
  invitedByUserId String?             @map("invited_by_user_id")
  joinedAt        DateTime?           @map("joined_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("CompanyMemberInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([role])
  @@map("company_members")
}

/// One-time set-password / invite tokens (schema only; issue/accept in provisioning sprint).
model AccountAccessToken {
  id        String                     @id @default(cuid())
  userId    String                     @map("user_id")
  purpose   AccountAccessTokenPurpose
  tokenHash String                     @unique @map("token_hash")
  expiresAt DateTime                   @map("expires_at")
  usedAt    DateTime?                  @map("used_at")
  createdAt DateTime                   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("account_access_tokens")
}

/// Public/draft/archived gate for catalog entities.
enum PublicationStatus {
  draft
  published
  archived
}

/// Sellable apartment inventory status (Constructor CRM is SoT after CRM is live).
enum ApartmentSalesStatus {
  available
  reserved
  sold
}

/// How apartment price is shown on public surfaces.
enum PriceVisibility {
  public
  by_request
  visible_after_login
}

/// Origin of the current apartment sales status.
enum CrmStatusSource {
  manual
  crm
  import
}

/// Shared media metadata (file upload pipeline comes later; URL fields only).
enum MediaAssetType {
  image
  video
  document
  other
}

model MediaAsset {
  id                String         @id @default(cuid())
  ownerCompanyId    String?        @map("owner_company_id")
  relatedEntityType String?        @map("related_entity_type")
  relatedEntityId   String?        @map("related_entity_id")
  type              MediaAssetType
  fileUrl           String         @map("file_url")
  thumbnailUrl      String?        @map("thumbnail_url")
  title             String?
  altText           String?        @map("alt_text")
  width             Int?
  height            Int?
  sortOrder         Int            @default(0) @map("sort_order")
  uploadedByUserId  String?        @map("uploaded_by_user_id")
  createdAt         DateTime       @default(now()) @map("created_at")

  ownerCompany   Company?   @relation("MediaOwnerCompany", fields: [ownerCompanyId], references: [id], onDelete: SetNull)
  companyLogos      Company[]       @relation("CompanyLogo")
  projectCovers     Project[]       @relation("ProjectCover")
  buildingCovers    Building[]      @relation("BuildingCover")
  floorPlans        Floor[]         @relation("FloorPlan")
  apartmentPlans    Apartment[]     @relation("ApartmentPlan")
  partnerLogos      PartnerCompany[] @relation("PartnerLogo")
  partnerCovers     PartnerCompany[] @relation("PartnerCover")
  venueMaps         VenueMap[]
  visualMapCanvases VisualMapCanvas[]

  @@index([ownerCompanyId])
  @@index([relatedEntityType, relatedEntityId])
  @@map("media_assets")
}

model Project {
  id                  String            @id @default(cuid())
  builderCompanyId    String            @map("builder_company_id")
  name                String
  slug                String            @unique
  publicationStatus   PublicationStatus @default(draft) @map("publication_status")
  shortDescription    String?           @map("short_description")
  fullDescription     String?           @map("full_description")
  locationText        String?           @map("location_text")
  address             String?
  city                String?
  district            String?
  latitude            Decimal?          @db.Decimal(10, 7)
  longitude           Decimal?          @db.Decimal(10, 7)
  coverMediaId        String?           @map("cover_media_id")
  projectType         String?           @map("project_type")
  constructionStatus  String?           @map("construction_status")
  completionDate      DateTime?         @map("completion_date") @db.Date
  amenities           Json?
  nearbyPlaces        Json?             @map("nearby_places")
  createdByUserId     String?           @map("created_by_user_id")
  updatedByUserId     String?           @map("updated_by_user_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  builderCompany Company     @relation(fields: [builderCompanyId], references: [id], onDelete: Restrict)
  coverMedia     MediaAsset? @relation("ProjectCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  buildings      Building[]
  apartments     Apartment[]
  requests             Request[]
  crmDeals             CrmDeal[]
  readinessAssessments ReadinessAssessment[]
  boothAssignments     BoothAssignment[]
  visualMapCanvases    VisualMapCanvas[]

  @@index([builderCompanyId])
  @@index([publicationStatus])
  @@index([city])
  @@map("projects")
}

model Building {
  id                String            @id @default(cuid())
  projectId         String            @map("project_id")
  name              String
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  description       String?
  displayOrder      Int               @default(0) @map("display_order")
  floorsCount       Int?              @map("floors_count")
  coverMediaId      String?           @map("cover_media_id")
  internalCode      String?           @map("internal_code")
  createdByUserId   String?           @map("created_by_user_id")
  updatedByUserId   String?           @map("updated_by_user_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coverMedia MediaAsset? @relation("BuildingCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  floors     Floor[]
  apartments Apartment[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([publicationStatus])
  @@map("buildings")
}

model Floor {
  id                String            @id @default(cuid())
  buildingId        String            @map("building_id")
  number            Int
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  name              String?
  displayLabel      String?           @map("display_label")
  displayOrder      Int               @default(0) @map("display_order")
  floorplanMediaId  String?           @map("floorplan_media_id")
  description       String?
  createdByUserId   String?           @map("created_by_user_id")
  updatedByUserId   String?           @map("updated_by_user_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  building       Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floorplanMedia MediaAsset? @relation("FloorPlan", fields: [floorplanMediaId], references: [id], onDelete: SetNull)
  apartments     Apartment[]

  @@unique([buildingId, number])
  @@index([buildingId])
  @@index([publicationStatus])
  @@map("floors")
}

model Apartment {
  id                      String               @id @default(cuid())
  projectId               String               @map("project_id")
  buildingId              String               @map("building_id")
  floorId                 String               @map("floor_id")
  number                  String
  salesStatus             ApartmentSalesStatus @default(available) @map("sales_status")
  publicationStatus       PublicationStatus    @default(draft) @map("publication_status")
  rooms                   Int?
  bedrooms                Int?
  bathrooms               Int?
  areaTotal               Decimal?             @map("area_total") @db.Decimal(10, 2)
  areaLiving              Decimal?             @map("area_living") @db.Decimal(10, 2)
  balconyArea             Decimal?             @map("balcony_area") @db.Decimal(10, 2)
  /// Amount in `priceCurrency` major units (e.g. AMD). ADAPTIVE: confirm minor-unit storage later.
  price                   Decimal?             @db.Decimal(14, 2)
  priceCurrency           String               @default("AMD") @map("price_currency")
  priceVisibility         PriceVisibility      @default(public) @map("price_visibility")
  description             String?
  planMediaId             String?              @map("plan_media_id")
  matterportUrl           String?              @map("matterport_url")
  external3dUrl           String?              @map("external_3d_url")
  orientation             String?
  viewType                String?              @map("view_type")
  features                Json?
  crmStatusSource         CrmStatusSource      @default(manual) @map("crm_status_source")
  activeCrmDealId         String?              @map("active_crm_deal_id")
  reservedUntil           DateTime?            @map("reserved_until")
  lastStatusChangedAt     DateTime?            @map("last_status_changed_at")
  lastStatusChangedByUserId String?            @map("last_status_changed_by_user_id")
  internalCode            String?              @map("internal_code")
  importExternalId        String?              @map("import_external_id")
  createdByUserId         String?              @map("created_by_user_id")
  updatedByUserId         String?              @map("updated_by_user_id")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  project       Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  building      Building                  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor         Floor                     @relation(fields: [floorId], references: [id], onDelete: Cascade)
  planMedia     MediaAsset?               @relation("ApartmentPlan", fields: [planMediaId], references: [id], onDelete: SetNull)
  statusHistory ApartmentStatusHistory[]
  requests      Request[]
  dealLinks     CrmDealApartmentLink[]

  @@unique([floorId, number])
  @@index([projectId])
  @@index([buildingId])
  @@index([floorId])
  @@index([publicationStatus])
  @@index([salesStatus])
  @@index([price])
  @@index([rooms])
  @@index([publicationStatus, salesStatus])
  @@index([projectId, publicationStatus])
  @@map("apartments")
}

/// Audit trail for apartment sales status changes (price/publication history can extend later).
model ApartmentStatusHistory {
  id              String                @id @default(cuid())
  apartmentId     String                @map("apartment_id")
  previousStatus  ApartmentSalesStatus? @map("previous_status")
  newStatus       ApartmentSalesStatus  @map("new_status")
  reason          String?
  changedByUserId String?               @map("changed_by_user_id")
  linkedDealId    String?               @map("linked_deal_id")
  createdAt       DateTime              @default(now()) @map("created_at")

  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId])
  @@index([createdAt])
  @@map("apartment_status_history")
}

/// Localized public catalog text (hy / ru / en). Scalar columns remain Armenian fallbacks.
model Translation {
  id              String   @id @default(cuid())
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  fieldName       String   @map("field_name")
  locale          String
  value           String
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([entityType, entityId, fieldName, locale])
  @@index([entityType, entityId])
  @@index([locale])
  @@map("translations")
}

/// Canonical deal/request creation source (unified intake use case).
enum RequestSource {
  buyer_project_request
  builder_buyer_qr_scan
  manual_builder_entry
  event_interaction
}

/// Intake request lifecycle (deal owns the sales pipeline).
enum RequestStatus {
  submitted
  attached
  cancelled
}

/// Constructor CRM pipeline status (docs: CRM-Pipeline-And-Statuses).
enum CrmDealStatus {
  new_request
  assigned
  contacted
  follow_up_needed
  apartment_selected
  reserved
  converted
  closed
  lost
}

enum CrmDealApartmentLinkType {
  interest
  selected
  reserved
  sold
}

enum CrmNoteVisibility {
  internal
}

enum CrmActivityType {
  call
  email
  meeting
  send_offer
  follow_up
  status_update
  other
}

enum CrmActivityStatus {
  planned
  done
  cancelled
}

/// Intake request from buyer/QR/manual sources. Many requests may attach to one deal.
model Request {
  id               String         @id @default(cuid())
  /// Null for manual CRM-only contacts without a registered buyer.
  buyerProfileId   String?        @map("buyer_profile_id")
  builderCompanyId String         @map("builder_company_id")
  projectId        String?        @map("project_id")
  apartmentId      String?        @map("apartment_id")
  source           RequestSource
  status           RequestStatus  @default(submitted)
  note             String?
  scanEventId      String?        @map("scan_event_id")
  createdByUserId  String?        @map("created_by_user_id")
  crmDealId        String?        @map("crm_deal_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  buyerProfile   BuyerProfile? @relation(fields: [buyerProfileId], references: [id], onDelete: SetNull)
  builderCompany Company       @relation(fields: [builderCompanyId], references: [id], onDelete: Restrict)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  apartment      Apartment?    @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
  scanEvent      QrScanEvent?  @relation(fields: [scanEventId], references: [id], onDelete: SetNull)
  createdBy      User?         @relation("RequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  crmDeal        CrmDeal?      @relation(fields: [crmDealId], references: [id], onDelete: SetNull)
  primaryForDeals CrmDeal[]    @relation("CrmDealPrimaryRequest")

  @@index([buyerProfileId])
  @@index([builderCompanyId])
  @@index([projectId])
  @@index([apartmentId])
  @@index([source])
  @@index([status])
  @@index([crmDealId])
  @@index([scanEventId])
  @@index([createdAt])
  @@map("requests")
}

/// Constructor CRM work item (one open deal per builder+buyer via intake dedup).
model CrmDeal {
  id               String        @id @default(cuid())
  companyId        String        @map("company_id")
  buyerProfileId   String?       @map("buyer_profile_id")
  primaryRequestId String?       @map("primary_request_id")
  source           RequestSource
  status           CrmDealStatus @default(new_request)
  title            String?
  message          String?
  /// Manual entry contact fields when no BuyerProfile is linked yet.
  contactName      String?       @map("contact_name")
  contactPhone     String?       @map("contact_phone")
  contactEmail     String?       @map("contact_email")
  assignedUserId   String?       @map("assigned_user_id")
  createdByUserId  String?       @map("created_by_user_id")
  lostReason       String?       @map("lost_reason")
  lastActivityAt   DateTime?     @map("last_activity_at")
  nextFollowUpAt   DateTime?     @map("next_follow_up_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  buyerProfile   BuyerProfile?           @relation(fields: [buyerProfileId], references: [id], onDelete: SetNull)
  primaryRequest Request?                @relation("CrmDealPrimaryRequest", fields: [primaryRequestId], references: [id], onDelete: SetNull)
  assignedUser   User?                   @relation("CrmDealAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy      User?                   @relation("CrmDealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  projectId      String?                 @map("project_id")
  project        Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requests       Request[]
  apartmentLinks CrmDealApartmentLink[]
  notes          CrmNote[]
  activities     CrmFollowUpActivity[]

  @@index([companyId])
  @@index([buyerProfileId])
  @@index([status])
  @@index([source])
  @@index([projectId])
  @@index([assignedUserId])
  @@index([updatedAt])
  @@index([companyId, buyerProfileId, status])
  /// SQL partial unique (see migration crm_one_open_deal): at most one open
  /// deal per (company_id, buyer_profile_id) where status is in the open set
  /// and buyer_profile_id IS NOT NULL. Prisma cannot express partial uniques.
  @@map("crm_deals")
}

model CrmDealApartmentLink {
  id                         String                    @id @default(cuid())
  crmDealId                  String                    @map("crm_deal_id")
  apartmentId                String                    @map("apartment_id")
  linkType                   CrmDealApartmentLinkType  @default(interest) @map("link_type")
  isPrimary                  Boolean                   @default(false) @map("is_primary")
  apartmentSalesStatusAtLink ApartmentSalesStatus?     @map("apartment_sales_status_at_link")
  priceAtLink                Decimal?                  @map("price_at_link") @db.Decimal(14, 2)
  priceVisibilityAtLink      PriceVisibility?          @map("price_visibility_at_link")
  createdByUserId            String?                   @map("created_by_user_id")
  createdAt                  DateTime                  @default(now()) @map("created_at")

  crmDeal         CrmDeal    @relation(fields: [crmDealId], references: [id], onDelete: Cascade)
  apartment       Apartment  @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  createdBy       User?      @relation("CrmApartmentLinkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([crmDealId, apartmentId])
  @@index([crmDealId])
  @@index([apartmentId])
  @@map("crm_deal_apartment_links")
}

model CrmNote {
  id           String            @id @default(cuid())
  crmDealId    String            @map("crm_deal_id")
  authorUserId String            @map("author_user_id")
  body         String
  visibility   CrmNoteVisibility @default(internal)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  crmDeal CrmDeal @relation(fields: [crmDealId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([crmDealId])
  @@index([authorUserId])
  @@index([createdAt])
  @@map("crm_notes")
}

model CrmFollowUpActivity {
  id              String            @id @default(cuid())
  crmDealId       String            @map("crm_deal_id")
  type            CrmActivityType
  title           String
  description     String?
  dueAt           DateTime?         @map("due_at")
  status          CrmActivityStatus @default(planned)
  assignedUserId  String?           @map("assigned_user_id")
  createdByUserId String            @map("created_by_user_id")
  completedAt     DateTime?         @map("completed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  crmDeal      CrmDeal @relation(fields: [crmDealId], references: [id], onDelete: Cascade)
  assignedUser User?   @relation("CrmActivityAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy    User    @relation("CrmActivityCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([crmDealId])
  @@index([status])
  @@index([dueAt])
  @@index([assignedUserId])
  @@map("crm_follow_up_activities")
}

/// Builder Readiness assessment target (company-wide or per project).
enum ReadinessAssessmentTargetType {
  builder_company
  project
}

/// Overall assessment and per-category score lifecycle.
enum ReadinessScoreStatus {
  not_started
  needs_improvement
  in_progress
  ready
  blocked
}

/// Builder-facing vs admin-only content on recommendations and required actions.
enum ReadinessVisibility {
  builder_visible
  internal_only
}

enum ReadinessRequiredActionStatus {
  open
  in_progress
  done
  blocked
  cancelled
}

model ReadinessAssessment {
  id                      String                        @id @default(cuid())
  targetType              ReadinessAssessmentTargetType @map("target_type")
  builderCompanyId        String                        @map("builder_company_id")
  projectId               String?                       @map("project_id")
  status                  ReadinessScoreStatus          @default(not_started)
  overallScore            Int?                          @map("overall_score")
  overallScoreOverridden  Boolean                       @default(false) @map("overall_score_overridden")
  evaluatedByUserId       String?                       @map("evaluated_by_user_id")
  lastEvaluatedAt         DateTime?                     @map("last_evaluated_at")
  archivedAt              DateTime?                     @map("archived_at")
  createdAt               DateTime                      @default(now()) @map("created_at")
  updatedAt               DateTime                      @updatedAt @map("updated_at")

  builderCompany   Company                   @relation(fields: [builderCompanyId], references: [id], onDelete: Restrict)
  project          Project?                  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  evaluatedBy      User?                     @relation("ReadinessAssessmentEvaluator", fields: [evaluatedByUserId], references: [id], onDelete: SetNull)
  scores           ReadinessScore[]
  recommendations  ReadinessRecommendation[]
  requiredActions  ReadinessRequiredAction[]
  internalNotes    ReadinessInternalNote[]

  @@index([builderCompanyId])
  @@index([projectId])
  @@index([status])
  @@index([builderCompanyId, targetType, archivedAt])
  @@index([projectId, archivedAt])
  @@map("readiness_assessments")
}

model ReadinessCategory {
  id                        String   @id @default(cuid())
  name                      String
  description               String?
  weight                    Int?
  sortOrder                 Int      @default(0) @map("sort_order")
  serviceProviderCategoryId String?                  @map("service_provider_category_id")
  active                    Boolean                  @default(true)
  createdAt                 DateTime                 @default(now()) @map("created_at")
  updatedAt                 DateTime                 @updatedAt @map("updated_at")

  scores                    ReadinessScore[]
  serviceProviderCategory   ServiceProviderCategory? @relation(fields: [serviceProviderCategoryId], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([sortOrder])
  @@index([serviceProviderCategoryId])
  @@map("readiness_categories")
}

model ReadinessScore {
  id                    String               @id @default(cuid())
  assessmentId          String               @map("assessment_id")
  categoryId            String               @map("category_id")
  score                 Int?
  status                ReadinessScoreStatus @default(not_started)
  recommendationSummary String?              @map("recommendation_summary")
  evaluatedByUserId     String?              @map("evaluated_by_user_id")
  evaluatedAt           DateTime?            @map("evaluated_at")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  assessment      ReadinessAssessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  category        ReadinessCategory         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  evaluatedBy     User?                     @relation("ReadinessScoreEvaluator", fields: [evaluatedByUserId], references: [id], onDelete: SetNull)
  recommendations ReadinessRecommendation[]
  requiredActions ReadinessRequiredAction[]
  internalNotes   ReadinessInternalNote[]

  @@unique([assessmentId, categoryId])
  @@index([assessmentId])
  @@index([categoryId])
  @@map("readiness_scores")
}

model ReadinessRecommendation {
  id              String              @id @default(cuid())
  assessmentId    String              @map("assessment_id")
  scoreId         String?             @map("score_id")
  title           String
  description     String
  visibility      ReadinessVisibility
  sortOrder       Int                 @default(0) @map("sort_order")
  createdByUserId String              @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  assessment ReadinessAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  score      ReadinessScore?     @relation(fields: [scoreId], references: [id], onDelete: SetNull)
  createdBy  User                @relation("ReadinessRecommendationCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([assessmentId])
  @@index([scoreId])
  @@index([visibility])
  @@map("readiness_recommendations")
}

model ReadinessRequiredAction {
  id                String                        @id @default(cuid())
  assessmentId      String                        @map("assessment_id")
  scoreId           String?                       @map("score_id")
  title             String
  description       String?
  status            ReadinessRequiredActionStatus @default(open)
  relatedEntityType String?                       @map("related_entity_type")
  relatedEntityId   String?                       @map("related_entity_id")
  visibility        ReadinessVisibility
  createdByUserId   String                        @map("created_by_user_id")
  createdAt         DateTime                      @default(now()) @map("created_at")
  updatedAt         DateTime                      @updatedAt @map("updated_at")

  assessment ReadinessAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  score      ReadinessScore?     @relation(fields: [scoreId], references: [id], onDelete: SetNull)
  createdBy  User                @relation("ReadinessRequiredActionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([assessmentId])
  @@index([scoreId])
  @@index([status])
  @@index([visibility])
  @@map("readiness_required_actions")
}

model ReadinessInternalNote {
  id           String   @id @default(cuid())
  assessmentId String   @map("assessment_id")
  scoreId      String?  @map("score_id")
  authorUserId String   @map("author_user_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assessment ReadinessAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  score      ReadinessScore?     @relation(fields: [scoreId], references: [id], onDelete: SetNull)
  author     User                @relation("ReadinessInternalNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([assessmentId])
  @@index([scoreId])
  @@index([authorUserId])
  @@map("readiness_internal_notes")
}

/// Partner profile type (display category on public partner pages).
enum PartnerCompanyType {
  builder
  bank
  it_company
  sponsor
  supplier
  insurance
  legal
  design_furniture
  service_company
  other
}

enum PartnerCompanyStatus {
  active
  inactive
}

/// Public partner profile linked 1:1 to a Company (partner / bank / service).
model PartnerCompany {
  id                String               @id @default(cuid())
  companyId         String               @unique @map("company_id")
  type              PartnerCompanyType
  name              String
  slug              String               @unique
  logoMediaId       String?              @map("logo_media_id")
  coverMediaId      String?              @map("cover_media_id")
  shortDescription  String?              @map("short_description")
  fullDescription   String?              @map("full_description")
  contacts          Json?
  website           String?
  socialLinks       Json?                @map("social_links")
  status            PartnerCompanyStatus @default(active)
  publicationStatus PublicationStatus    @default(draft) @map("publication_status")
  featured          Boolean              @default(false)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logoMedia  MediaAsset?    @relation("PartnerLogo", fields: [logoMediaId], references: [id], onDelete: SetNull)
  coverMedia MediaAsset?    @relation("PartnerCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  offers     PartnerOffer[]
  bankOffers BankOffer[]

  @@index([slug])
  @@index([companyId])
  @@index([type, publicationStatus])
  @@map("partner_companies")
}

/// Generic partner offer/service (non-bank; BankOffer is a separate Mortgage entity).
model PartnerOffer {
  id                String            @id @default(cuid())
  partnerCompanyId  String            @map("partner_company_id")
  title             String
  description       String?
  type              String?
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  sortOrder         Int               @default(0) @map("sort_order")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  partnerCompany PartnerCompany @relation(fields: [partnerCompanyId], references: [id], onDelete: Cascade)

  @@index([partnerCompanyId])
  @@index([publicationStatus])
  @@map("partner_offers")
}

/// Mortgage offer terms for bank partners (Mortgage module).
model BankOffer {
  id                    String            @id @default(cuid())
  partnerCompanyId      String            @map("partner_company_id")
  title                 String
  shortDescription      String?           @map("short_description")
  /// Annual interest rate in percent (e.g. 12.5).
  rate                  Decimal           @db.Decimal(5, 2)
  apr                   Decimal?          @db.Decimal(5, 2)
  minDownPaymentPercent Decimal           @map("min_down_payment_percent") @db.Decimal(5, 2)
  termOptionsYears      Int[]             @map("term_options_years")
  fees                  String?
  calculationNotes      String?           @map("calculation_notes")
  featured              Boolean           @default(false)
  sortOrder             Int               @default(0) @map("sort_order")
  publicationStatus     PublicationStatus @default(draft) @map("publication_status")
  createdByUserId       String            @map("created_by_user_id")
  updatedByUserId       String?           @map("updated_by_user_id")
  publishedAt           DateTime?         @map("published_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  partnerCompany PartnerCompany @relation(fields: [partnerCompanyId], references: [id], onDelete: Cascade)
  createdBy      User           @relation("BankOfferCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy      User?          @relation("BankOfferUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([partnerCompanyId])
  @@index([publicationStatus])
  @@map("bank_offers")
}

enum ServiceProviderType {
  company
  person
  team
  other
}

model ServiceProviderCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  providers           ServiceProviderCategoryLink[]
  readinessCategories ReadinessCategory[]

  @@index([active])
  @@index([sortOrder])
  @@map("service_provider_categories")
}

model ServiceProvider {
  id                String               @id @default(cuid())
  name              String
  providerType      ServiceProviderType  @map("provider_type")
  description       String?
  services          String?
  phone             String?
  email             String?
  website           String?
  socialLinks       Json?                @map("social_links")
  internalNotes     String?              @map("internal_notes")
  active            Boolean              @default(true)
  publicationStatus PublicationStatus?   @map("publication_status")
  createdByUserId   String               @map("created_by_user_id")
  updatedByUserId   String?              @map("updated_by_user_id")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  categories ServiceProviderCategoryLink[]
  createdBy  User                          @relation("ServiceProviderCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy  User?                         @relation("ServiceProviderUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([providerType])
  @@index([publicationStatus])
  @@map("service_providers")
}

model ServiceProviderCategoryLink {
  serviceProviderId         String @map("service_provider_id")
  serviceProviderCategoryId String @map("service_provider_category_id")

  serviceProvider ServiceProvider         @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  category        ServiceProviderCategory @relation(fields: [serviceProviderCategoryId], references: [id], onDelete: Cascade)

  @@id([serviceProviderId, serviceProviderCategoryId])
  @@index([serviceProviderCategoryId])
  @@map("service_provider_category_links")
}

/// Exhibition event lifecycle status.
enum EventStatus {
  planning
  active
  completed
  archived
  cancelled
}

/// Physical booth / stand type on the venue map.
enum BoothType {
  builder
  bank
  partner
  sponsor
  service
  info
  entrance
  other
}

/// Route graph node type for pathfinding.
enum RouteNodeType {
  entrance
  intersection
  booth
  info
  other
}

/// Entrance check-in outcome.
enum CheckInStatus {
  allowed
  denied_invalid_qr
  denied_blocked
  duplicate_checkin
  error
}

model Event {
  id                String            @id @default(cuid())
  name              String
  code              String            @unique
  startDate         DateTime?         @map("start_date") @db.Date
  endDate           DateTime?         @map("end_date") @db.Date
  status            EventStatus       @default(planning)
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  venueMaps      VenueMap[]
  booths         Booth[]
  checkInRecords CheckInRecord[]

  @@index([status])
  @@index([publicationStatus])
  @@map("events")
}

model VenueMap {
  id                String            @id @default(cuid())
  eventId           String            @map("event_id")
  title             String
  mediaAssetId      String            @map("media_asset_id")
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  width             Int?
  height            Int?
  createdByUserId   String            @map("created_by_user_id")
  updatedByUserId   String?           @map("updated_by_user_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  mediaAsset  MediaAsset  @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)
  createdBy   User        @relation("VenueMapCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy   User?       @relation("VenueMapUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  booths      Booth[]
  routeNodes  RouteNode[]
  routeEdges  RouteEdge[]

  @@index([eventId])
  @@index([publicationStatus])
  @@map("venue_maps")
}

model Booth {
  id                String            @id @default(cuid())
  eventId           String            @map("event_id")
  venueMapId        String            @map("venue_map_id")
  code              String
  name              String?
  type              BoothType
  xPercent          Decimal           @map("x_percent") @db.Decimal(6, 3)
  yPercent          Decimal           @map("y_percent") @db.Decimal(6, 3)
  shapeData         Json?             @map("shape_data")
  locationText      String?           @map("location_text")
  publicationStatus PublicationStatus @default(draft) @map("publication_status")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venueMap    VenueMap          @relation(fields: [venueMapId], references: [id], onDelete: Cascade)
  assignments BoothAssignment[]
  routeNodes  RouteNode[]

  @@unique([eventId, code])
  @@index([venueMapId])
  @@index([publicationStatus])
  @@map("booths")
}

/// Booth occupant — single companyId covers builder/partner/bank (Company.type disambiguates).
model BoothAssignment {
  id              String   @id @default(cuid())
  boothId         String   @map("booth_id")
  companyId       String?  @map("company_id")
  projectId       String?  @map("project_id")
  assignmentLabel String?  @map("assignment_label")
  sortOrder       Int?     @map("sort_order")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  booth   Booth    @relation(fields: [boothId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([boothId])
  @@index([companyId])
  @@index([projectId])
  @@map("booth_assignments")
}

model RouteNode {
  id         String        @id @default(cuid())
  venueMapId String        @map("venue_map_id")
  code       String?
  label      String?
  xPercent   Decimal       @map("x_percent") @db.Decimal(6, 3)
  yPercent   Decimal       @map("y_percent") @db.Decimal(6, 3)
  type       RouteNodeType
  boothId    String?       @map("booth_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  venueMap  VenueMap    @relation(fields: [venueMapId], references: [id], onDelete: Cascade)
  booth     Booth?      @relation(fields: [boothId], references: [id], onDelete: SetNull)
  edgesFrom RouteEdge[] @relation("RouteEdgeFrom")
  edgesTo   RouteEdge[] @relation("RouteEdgeTo")

  @@index([venueMapId])
  @@index([boothId])
  @@map("route_nodes")
}

model RouteEdge {
  id         String   @id @default(cuid())
  venueMapId String   @map("venue_map_id")
  fromNodeId String   @map("from_node_id")
  toNodeId   String   @map("to_node_id")
  weight     Decimal? @db.Decimal(10, 4)
  accessible Boolean?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  venueMap VenueMap  @relation(fields: [venueMapId], references: [id], onDelete: Cascade)
  fromNode RouteNode @relation("RouteEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   RouteNode @relation("RouteEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId])
  @@index([venueMapId])
  @@map("route_edges")
}

model CheckInRecord {
  id                   String        @id @default(cuid())
  eventId              String        @map("event_id")
  buyerProfileId       String        @map("buyer_profile_id")
  qrCodeId             String        @map("qr_code_id")
  scanEventId          String?       @map("scan_event_id")
  checkedInByUserId    String        @map("checked_in_by_user_id")
  status               CheckInStatus
  checkedInAt          DateTime      @map("checked_in_at")
  duplicateOfCheckInId String?       @map("duplicate_of_check_in_id")
  createdAt            DateTime      @default(now()) @map("created_at")

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  buyerProfile    BuyerProfile    @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  qrCode          QrCode          @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  scanEvent       QrScanEvent?    @relation(fields: [scanEventId], references: [id], onDelete: SetNull)
  checkedInBy     User            @relation("CheckInStaff", fields: [checkedInByUserId], references: [id], onDelete: Restrict)
  duplicateOf     CheckInRecord?  @relation("DuplicateCheckIn", fields: [duplicateOfCheckInId], references: [id], onDelete: SetNull)
  duplicateScans  CheckInRecord[] @relation("DuplicateCheckIn")

  /// Partial unique: at most one `allowed` per (eventId, buyerProfileId).
  /// Enforced via raw SQL partial index in migration — Prisma cannot express it.
  @@index([eventId])
  @@index([buyerProfileId])
  @@index([checkedInByUserId])
  @@index([status])
  @@index([checkedInAt])
  @@map("check_in_records")
}

/// Product analytics event types (v1).
enum AnalyticsEventType {
  project_view
  building_view
  floor_view
  apartment_view
  builder_profile_view
  partner_profile_view
  mortgage_page_view
  bank_offer_selected
  favorite_added
  request_created
  qr_scanned
  check_in_recorded
  booth_selected
  route_requested
  crm_status_changed
  readiness_status_changed

  @@map("analytics_event_type")
}

/// Append-only analytics events. Entity id columns are plain strings (no FK) so
/// analytics never blocks or cascades with domain data lifecycle.
model AnalyticsEvent {
  id          String             @id @default(cuid())
  eventType   AnalyticsEventType @map("event_type")
  actorUserId String?            @map("actor_user_id")
  actorRole   String?            @map("actor_role")
  companyId   String?            @map("company_id")
  projectId   String?            @map("project_id")
  buildingId  String?            @map("building_id")
  floorId     String?            @map("floor_id")
  apartmentId String?            @map("apartment_id")
  eventId     String?            @map("event_id")
  boothId     String?            @map("booth_id")
  requestId   String?            @map("request_id")
  crmDealId   String?            @map("crm_deal_id")
  source      String?
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([companyId, createdAt])
  @@index([projectId, createdAt])
  @@map("analytics_events")
}

/// BOS inbound provisioning lifecycle (idempotency key = requestId).
enum BosProvisioningStatus {
  success
  linked_existing
  failed
  partial
}

/// Company type accepted on the BOS provisioning wire contract.
enum BosProvisioningCompanyType {
  builder
  partner
  bank
}

/// Append-only integration audit trail for BOS provisioning.
enum IntegrationAuditAction {
  provisioning_received
  company_created
  company_linked
  user_created
  user_linked
  member_created
  invitation_sent
  provisioning_failed
  provisioning_retried
  result_returned
}

model BosProvisioningRequest {
  id                  String                     @id @default(cuid())
  requestId           String                     @unique @map("request_id")
  bosCompanyId        String                     @map("bos_company_id")
  companyName         String                     @map("company_name")
  companyType         BosProvisioningCompanyType @map("company_type")
  primaryContactName  String                     @map("primary_contact_name")
  primaryContactEmail String                     @map("primary_contact_email")
  primaryContactPhone String?                    @map("primary_contact_phone")
  eventCycleId        String?                    @map("event_cycle_id")
  eventCycleName      String?                    @map("event_cycle_name")
  requestedModules    String[]                   @map("requested_modules")
  status              BosProvisioningStatus
  toonexpoCompanyId   String?                    @map("toonexpo_company_id")
  primaryUserId       String?                    @map("primary_user_id")
  errorMessage        String?                    @map("error_message")
  attemptCount        Int                        @default(1) @map("attempt_count")
  createdAt           DateTime                   @default(now()) @map("created_at")
  updatedAt           DateTime                   @updatedAt @map("updated_at")

  auditLogs IntegrationAuditLog[]

  @@index([bosCompanyId])
  @@index([status])
  @@index([primaryContactEmail])
  @@index([createdAt])
  @@map("bos_provisioning_requests")
}

model IntegrationAuditLog {
  id                    String                 @id @default(cuid())
  action                IntegrationAuditAction
  provisioningRequestId String?                @map("provisioning_request_id")
  details               Json?
  createdAt             DateTime               @default(now()) @map("created_at")

  provisioningRequest BosProvisioningRequest? @relation(fields: [provisioningRequestId], references: [id], onDelete: SetNull)

  @@index([provisioningRequestId, createdAt])
  @@map("integration_audit_logs")
}

/// Visual map canvas context (project / building / floor layer).
enum VisualMapContextType {
  project
  building
  floor
}

/// Hotspot navigation target on a visual map canvas.
enum VisualHotspotTargetType {
  building
  floor
  apartment
}

/// Image canvas with clickable hotspots for real-estate navigation.
model VisualMapCanvas {
  id                String               @id @default(cuid())
  ownerCompanyId    String               @map("owner_company_id")
  projectId         String               @map("project_id")
  contextType       VisualMapContextType @map("context_type")
  /// Polymorphic reference: contextId points to Project.id, Building.id, or Floor.id per contextType.
  contextId         String               @map("context_id")
  mediaAssetId      String               @map("media_asset_id")
  title             String?
  description       String?
  publicationStatus PublicationStatus    @default(draft) @map("publication_status")
  /// Only one primary canvas per (contextType, contextId) — enforced in service layer.
  isPrimary         Boolean              @default(false) @map("is_primary")
  sortOrder         Int                  @default(0) @map("sort_order")
  createdByUserId   String               @map("created_by_user_id")
  updatedByUserId   String?              @map("updated_by_user_id")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  ownerCompany Company         @relation(fields: [ownerCompanyId], references: [id], onDelete: Restrict)
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset      @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)
  createdBy    User            @relation("VisualMapCanvasCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy    User?           @relation("VisualMapCanvasUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  hotspots     VisualHotspot[]

  @@index([projectId, contextType, contextId])
  @@index([ownerCompanyId])
  @@index([publicationStatus])
  @@map("visual_map_canvases")
}

/// Clickable marker on a visual map canvas.
model VisualHotspot {
  id                String                  @id @default(cuid())
  canvasId          String                  @map("canvas_id")
  targetType        VisualHotspotTargetType @map("target_type")
  targetId          String                  @map("target_id")
  label             String
  xPercent          Decimal                 @map("x_percent") @db.Decimal(6, 3)
  yPercent          Decimal                 @map("y_percent") @db.Decimal(6, 3)
  markerStyle       String?                 @map("marker_style")
  publicationStatus PublicationStatus       @default(draft) @map("publication_status")
  sortOrder         Int?                    @map("sort_order")
  createdByUserId   String                  @map("created_by_user_id")
  updatedByUserId   String?                 @map("updated_by_user_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  canvas    VisualMapCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  createdBy User            @relation("VisualHotspotCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy User?           @relation("VisualHotspotUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([canvasId])
  @@index([publicationStatus])
  @@map("visual_hotspots")
}
